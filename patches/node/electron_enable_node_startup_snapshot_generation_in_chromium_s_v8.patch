-  code_cache_->map.reserve(in.size());
-  DCHECK(code_cache_->map.empty());
+  // Electron: this can be called twice -- once with the code cache from a
+  // Node startup snapshot (populated in Environment::Deserialize for
+  // node-internal builtins), and once with Electron's build-time js2c cache
+  // for the electron/js2c/* framework bundles which the snapshot does not
+  // cover. Merge rather than replace; the caches cover disjoint id sets.
