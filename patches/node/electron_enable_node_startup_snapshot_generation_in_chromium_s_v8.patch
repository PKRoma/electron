+// Electron: V8's [fastapi] CL "Store callback and signature in one C++ object"
+// changed FunctionTemplateRareData::c_function_overloads to store
+// Managed<CFunctionWithSignature> -- a Foreign holding a heap-allocated
+// ManagedPtrDestructor*, not the static CFunctionInfo* the embedder
+// registers. V8's snapshot serializer cannot encode that heap pointer as an
+// external reference, so any FunctionTemplate with a fast-API c_function
+// makes snapshot creation abort at SerializedHandleChecker / encoder.
+// Drop c_function when building a snapshot; the deserialized template uses
+// the (correct, just slower) slow callback. node_mksnapshot.cc sets the env
+// var; it is never set in shipped processes.
+static bool DropCFunctionForSnapshot() {
+  static const bool drop = getenv("NODE_MKSNAPSHOT_DROP_CFUNCTION") != nullptr;
+  return drop;
+}
+
 Local<v8::FunctionTemplate> NewFunctionTemplate(
     v8::Isolate* isolate,
     v8::FunctionCallback callback,
@@ -377,6 +393,9 @@ Local<v8::FunctionTemplate> NewFunctionTemplate(
     v8::ConstructorBehavior behavior,
     v8::SideEffectType side_effect_type,
     const v8::CFunction* c_function) {
+  if (c_function != nullptr && DropCFunctionForSnapshot()) {
+    c_function = nullptr;
+  }
   return v8::FunctionTemplate::New(isolate,
                                    callback,
                                    Local<v8::Value>(),
@@ -516,6 +535,7 @@ void SetFastMethod(Isolate* isolate,
                    const std::string_view name,
                    v8::FunctionCallback slow_callback,
                    const v8::MemorySpan<const v8::CFunction>& methods) {
+  // Electron: see DropCFunctionForSnapshot.
   Local<v8::FunctionTemplate> t = FunctionTemplate::NewWithCFunctionOverloads(
       isolate,
       slow_callback,
@@ -524,7 +544,8 @@ void SetFastMethod(Isolate* isolate,
       0,
       v8::ConstructorBehavior::kThrow,
       v8::SideEffectType::kHasSideEffect,
-      methods);
+      DropCFunctionForSnapshot() ? v8::MemorySpan<const v8::CFunction>{}
+                                 : methods);
 
   // kInternalized strings are created in the old space.
   const v8::NewStringType type = v8::NewStringType::kInternalized;
@@ -540,6 +561,7 @@ void SetFastMethodNoSideEffect(
     const std::string_view name,
     v8::FunctionCallback slow_callback,
     const v8::MemorySpan<const v8::CFunction>& methods) {
+  // Electron: see DropCFunctionForSnapshot.
   Local<v8::FunctionTemplate> t = FunctionTemplate::NewWithCFunctionOverloads(
       isolate,
       slow_callback,
@@ -548,7 +570,8 @@ void SetFastMethodNoSideEffect(
       0,
       v8::ConstructorBehavior::kThrow,
       v8::SideEffectType::kHasNoSideEffect,
-      methods);
+      DropCFunctionForSnapshot() ? v8::MemorySpan<const v8::CFunction>{}
