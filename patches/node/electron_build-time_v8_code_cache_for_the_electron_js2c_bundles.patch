diff --git a/unofficial.gni b/unofficial.gni
index 1285f83662e4f252faa1730df04cafc588cd7556..216bef46ff4b649a2d10a16b531b4328c5dbdebb 100644
--- a/unofficial.gni
+++ b/unofficial.gni
@@ -5,6 +5,7 @@
 import("node.gni")
 import("$node_v8_path/gni/snapshot_toolchain.gni")
 import("$node_v8_path/gni/v8.gni")
+import("//tools/v8_context_snapshot/v8_context_snapshot.gni")
 
 # The actual configurations are put inside a template in unofficial.gni to
 # prevent accidental edits from contributors.
@@ -348,6 +349,95 @@ template("node_gn_build") {
     }
   }
 
+  # Electron: build-time host tool emitting V8 code caches for the
+  # electron/js2c/* framework bundles. Built in v8_snapshot_toolchain (like
+  # node_mksnapshot) so it links V8 with V8_TARGET_ARCH set to the target and
+  # reads the target's snapshot blob -- the cache it emits is keyed to the
+  # target's read-only checksum and flag hash. Cross-OS stays off.
+  if (host_os == target_os) {
+    if (current_toolchain == v8_snapshot_toolchain) {
+      executable("electron_natives_codecache") {
+        # Host build tool, not shipped Chromium code.
+        configs += [
+          ":node_internal_config",
+          "//build/config/compiler:no_chromium_code",
+        ]
+        configs -= [ "//build/config/compiler:chromium_code" ]
+        sources =
+            [ "//electron/shell/common/electron_natives_codecache_main.cc" ]
+        # node's zstd binding also needs the compression symbols.
+        deps = [
+          ":libnode",
+          "//third_party/zstd:compress",
+        ]
+      }
+    }
+
+    # One generated cache per process flavor: V8's code-cache key includes
+    # FlagList::Hash() over non-default flags, which differs per process type.
+    # The flag deltas below were captured from live processes.
+    _js2c_cc_flavors = [
+      {
+        name = "sandbox"  # sandboxed renderer (no Node env)
+        snap = v8_context_snapshot_filename
+        flags = "--enable-sharedarraybuffer-per-context"
+      },
+      {
+        name = "renderer"
+        snap = v8_context_snapshot_filename
+        flags = "--enable-sharedarraybuffer-per-context --rehash-snapshot " +
+                "--no-freeze-flags-after-init"
+      },
+      {
+        name = "browser"
+        snap = v8_context_snapshot_filename
+        flags = "--rehash-snapshot --no-freeze-flags-after-init"
+      },
+      {
+        name = "utility"
+        snap = v8_context_snapshot_filename
+        flags = "--rehash-snapshot --no-freeze-flags-after-init"
+      },
+      {
+        name = "worker"
+        snap = v8_context_snapshot_filename
+        flags = "--rehash-snapshot --no-freeze-flags-after-init"
+      },
+    ]
+
+    foreach(_f, _js2c_cc_flavors) {
+      action("run_electron_natives_codecache_" + _f.name) {
+        deps = [
+          ":electron_natives_codecache($v8_snapshot_toolchain)",
+          "//tools/v8_context_snapshot:v8_context_snapshot",
+          "$node_v8_path:run_mksnapshot_default",
+        ]
+        script = "$node_v8_path/tools/run.py"
+        sources = []
+        gen_dir = get_label_info(
+                ":electron_natives_codecache($v8_snapshot_toolchain)",
+                "root_out_dir")
+        _out = "$root_gen_dir/electron_natives_code_cache_" + _f.name + ".cc"
+        outputs = [ _out ]
+        args = [
+          "./" + rebase_path(gen_dir + "/electron_natives_codecache",
+                             root_build_dir),
+          rebase_path(_out, root_build_dir),
+          rebase_path("$root_out_dir/" + _f.snap, root_build_dir),
+          _f.name,
+          _f.flags,
+        ]
+      }
+    }
+
+    group("run_electron_natives_codecache") {
+      public_deps = []
+      foreach(_f, _js2c_cc_flavors) {
+        public_deps += [ ":run_electron_natives_codecache_" + _f.name ]
+      }
+    }
+  }
+
   action("generate_config_gypi") {
     deps = [ "$node_v8_path:v8_generate_features_json" ]
     script = "tools/generate_config_gypi.py"
